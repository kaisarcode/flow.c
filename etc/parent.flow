flow.id=parent
flow.link=run-child

# Data used by child
flow.greeting=Hola

# Behavior node
node.reporter.exec=printf "Report: "; cat; printf "\n"
node.reporter.link=summary

# Use a heredoc for complex formatting
node.summary.exec=<<EOF
printf "========================================\n"
printf "Flow ID: <flow.id>\n"
printf "Output:  "
cat
printf "========================================\n"
EOF

# Run child and pipe to reporter
node.run-child.file=child.flow
node.run-child.hello=<flow.greeting>
node.run-child.link=reporter
