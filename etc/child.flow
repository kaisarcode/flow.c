flow.id=child
flow.hello=Hello
flow.world=World
flow.link=greet

# Data-only node for shared configuration
node.config.prefix=>>
node.config.suffix=<<

# Reusable template using node.use
node.base-exec.exec=printf "%s %s %s" "<node.config.prefix>" "<node.greeting> <node.name>" "<node.config.suffix>"

# Specialized node
node.greet.use=base-exec
node.greet.greeting=<flow.hello>
node.greet.name=<flow.world>
node.greet.link=final-touch

# Function expansion using a heredoc
func.mark.exec=<<EOF
printf "!!! %s !!!" "<arg.val>"
EOF

node.final-touch.exec=<func.mark final-touch.data>
node.final-touch.data.val=DONE
